#!/usr/bin/env python
"""Fetch and manage review comments from a GitHub PR.

Based on: https://stackoverflow.com/a/66072198/844449

Usage:
    gh-review get [PR_NUMBER]            # Get unresolved comments
    gh-review reply <thread_id> <file|-> # Reply to a review thread
"""

import json
import subprocess
import sys


def get_pr_number(arg_index: int = 1) -> int:
    """Get PR number from argument or current branch."""
    if len(sys.argv) > arg_index:
        try:
            return int(sys.argv[arg_index])
        except ValueError:
            pass

    # Try to get from current branch
    result = subprocess.run(
        ["gh", "pr", "view", "--json", "number", "--jq", ".number"],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        return int(result.stdout.strip())

    print("Error: Could not determine PR number", file=sys.stderr)
    sys.exit(1)


def get_repo_info() -> tuple[str, str]:
    """Get owner and repo from current directory."""
    result = subprocess.run(
        [
            "gh",
            "repo",
            "view",
            "--json",
            "owner,name",
            "--jq",
            "[.owner.login, .name] | @tsv",
        ],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        print("Error: Could not determine repository", file=sys.stderr)
        sys.exit(1)

    parts = result.stdout.strip().split("\t")
    return parts[0], parts[1]


def fetch_unresolved_comments(owner: str, repo: str, pr_number: int) -> list[dict]:
    """Fetch unresolved review threads from a PR using GraphQL."""
    query = """
    query($owner: String!, $repo: String!, $pr: Int!, $cursor: String) {
        repository(owner: $owner, name: $repo) {
            pullRequest(number: $pr) {
                reviewThreads(first: 100, after: $cursor) {
                    pageInfo {
                        hasNextPage
                        endCursor
                    }
                    nodes {
                        id
                        isResolved
                        isOutdated
                        path
                        line
                        comments(first: 20) {
                            nodes {
                                author {
                                    login
                                }
                                body
                                createdAt
                                url
                                id
                            }
                        }
                    }
                }
            }
        }
    }
    """

    variables = {
        "owner": owner,
        "repo": repo,
        "pr": pr_number,
        "cursor": None,
    }

    all_threads = []
    has_next_page = True

    while has_next_page:
        result = subprocess.run(
            [
                "gh",
                "api",
                "graphql",
                "-f",
                f"query={query}",
                "-f",
                f"owner={owner}",
                "-f",
                f"repo={repo}",
                "-F",
                f"pr={pr_number}",
                "-f",
                f"cursor={variables['cursor'] or ''}",
            ],
            capture_output=True,
            text=True,
        )

        if result.returncode != 0:
            print(f"Error: {result.stderr}", file=sys.stderr)
            sys.exit(1)

        data = json.loads(result.stdout)
        threads_data = data["data"]["repository"]["pullRequest"]["reviewThreads"]

        for thread in threads_data["nodes"]:
            if not thread["isResolved"]:
                all_threads.append(thread)

        has_next_page = threads_data["pageInfo"]["hasNextPage"]
        variables["cursor"] = threads_data["pageInfo"]["endCursor"]

    return all_threads


def print_threads(threads: list[dict]) -> None:
    """Print unresolved threads in a readable format."""
    if not threads:
        print("✅ No unresolved review comments!")
        return

    print(f"📋 Found {len(threads)} unresolved review thread(s):\n")

    # Track statistics
    total_threads = len(threads)
    outdated_count = 0
    responded_count = 0
    addressed_count = 0

    for thread in threads:
        path = thread["path"]
        line = thread.get("line", "?")
        is_outdated = thread["isOutdated"]
        outdated = " (outdated)" if is_outdated else ""

        # Check if thread has been responded to (more than one comment)
        has_response = len(thread["comments"]["nodes"]) > 1

        if is_outdated:
            outdated_count += 1

        if has_response:
            responded_count += 1

        # Thread is addressed if it has a response OR is outdated
        if has_response or is_outdated:
            addressed_count += 1

        # Get comment_id from the first comment in the thread
        first_comment = thread["comments"]["nodes"][0] if thread["comments"]["nodes"] else {}
        first_url = first_comment.get("url", "")
        thread_id = first_url.split("discussion_r")[-1] if "discussion_r" in first_url else "?"

        print(f"── Thread {thread_id}: {path}:{line}{outdated} ──")

        for idx, comment in enumerate(thread["comments"]["nodes"]):
            author = comment["author"]["login"] if comment["author"] else "unknown"
            body = comment["body"]
            url = comment["url"]
            # Extract numeric comment ID from URL (discussion_rNNNN)
            comment_id = url.split("discussion_r")[-1] if "discussion_r" in url else "?"

            # Add delimiter before comments after the first one
            if idx > 0:
                print(f"─── Response {comment_id} by @{author}:")
            print()
            # Print full body with indentation
            for line_text in body.split("\n"):
                print(f"{line_text}")
            print()
            print(f"🔗 Link: {url}")
            print()

        print(f"== Thread end {thread_id}: {path}:{line}{outdated} ==")

    # Print summary
    print("\n" + "=" * 40)
    print("📊 Summary:")
    print(f" * Addressed threads: {addressed_count} / {total_threads}")
    print(f" * Responded: {responded_count}")
    print(f" * Outdated: {outdated_count}")
    print("=" * 40)


def get_pr_for_comment(owner: str, repo: str, comment_id: str) -> int:
    """Get the PR number for a given comment ID."""
    # Use REST API to get comment info directly
    url = f"/repos/{owner}/{repo}/pulls/comments/{comment_id}"

    result = subprocess.run(
        [
            "gh",
            "api",
            url,
        ],
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        print(f"Error finding comment: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    data = json.loads(result.stdout)
    # Extract PR number from the pull_request_url
    # Format: https://api.github.com/repos/owner/repo/pulls/NUMBER
    pr_url = data.get("pull_request_url", "")
    if pr_url:
        pr_number = int(pr_url.rstrip("/").split("/")[-1])
        return pr_number

    print(f"Error: Could not find PR for comment {comment_id}", file=sys.stderr)
    sys.exit(1)


def reply_to_thread(owner: str, repo: str, pr_number: int, thread_id: str, body: str) -> None:
    """Reply to a review thread using the discussion_r ID."""
    # Use REST API to add a comment to the PR review thread
    url = f"/repos/{owner}/{repo}/pulls/{pr_number}/comments/{thread_id}/replies"

    result = subprocess.run(
        [
            "gh",
            "api",
            "-X",
            "POST",
            url,
            "-f",
            f"body={body}",
        ],
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        print(f"Error replying to thread: {result.stderr}", file=sys.stderr)
        sys.exit(1)

    print(f"✅ Successfully replied to thread {thread_id}")


def cmd_get(args: list[str]) -> None:
    """Handle 'get' command to fetch unresolved comments."""
    pr_number = get_pr_number(1 if len(args) > 0 else 0)
    owner, repo = get_repo_info()

    print(f"Fetching unresolved comments for {owner}/{repo}#{pr_number}...")
    threads = fetch_unresolved_comments(owner, repo, pr_number)
    print_threads(threads)


def cmd_reply(args: list[str]) -> None:
    """Handle 'reply' command to reply to a review thread."""
    if len(args) < 2:
        print("Usage: gh-review reply <thread_id> <file|->", file=sys.stderr)
        sys.exit(1)

    thread_id = args[0]
    body_source = args[1]

    # Read body from file or stdin
    if body_source == "-":
        body = sys.stdin.read()
    else:
        try:
            with open(body_source, "r") as f:
                body = f.read()
        except FileNotFoundError:
            print(f"Error: File not found: {body_source}", file=sys.stderr)
            sys.exit(1)

    if not body.strip():
        print("Error: Comment body is empty", file=sys.stderr)
        sys.exit(1)

    owner, repo = get_repo_info()

    # Find which PR this comment belongs to
    pr_number = get_pr_for_comment(owner, repo, thread_id)

    reply_to_thread(owner, repo, pr_number, thread_id, body)


def cmd_help() -> None:
    """Display help information."""
    help_text = """gh-review - Fetch and manage GitHub PR review comments

Usage:
    gh-review get [PR_NUMBER]            # Get unresolved comments
    gh-review reply <thread_id> <file|-> # Reply to a review thread
    gh-review help                       # Show this help message

Commands:
    get [PR_NUMBER]
        Fetch unresolved review comments for a PR.
        If PR_NUMBER is omitted, uses the current branch's PR.

    reply <thread_id> <file|->
        Reply to a review thread using its thread ID.
        Use '-' to read the comment body from stdin.
        Use a file path to read the comment body from a file.

Examples:
    gh-review get                        # Get comments for current PR
    gh-review get 123                    # Get comments for PR #123
    gh-review reply 1234567 response.md  # Reply with content from file
    echo "LGTM" | gh-review reply 1234567 -  # Reply with stdin
"""
    print(help_text)


def main() -> None:
    """Main entry point."""
    if len(sys.argv) < 2:
        print("Usage: gh-review <command>", file=sys.stderr)
        print("Run 'gh-review help' for usage information.", file=sys.stderr)
        sys.exit(1)

    command = sys.argv[1]

    if command == "get":
        cmd_get(sys.argv[2:])
    elif command == "reply":
        cmd_reply(sys.argv[2:])
    elif command in ("help", "-h", "--help"):
        cmd_help()
    else:
        print(f"Unknown command: {command}", file=sys.stderr)
        print("Run 'gh-review help' for usage information.", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
